  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
      <h2>Mari Terhubung</h2>
      
      <div class="contact-content">
        <div class="contact-info">
          <h3>Hubungi Saya</h3>
          <p>Saya terbuka untuk diskusi tentang cybersecurity, networking, atau peluang kolaborasi. Jangan ragu untuk menghubungi!</p>
          
          <div class="contact-methods">
            <div class="contact-method">
              <span class="method-icon">📧</span>
              <div>
                <p class="method-label">Email</p>
                <a href="mailto:alvaroprayogo38@gmail.com">alvaroprayogo38@gmail.com</a>
              </div>
            </div>

            <div class="contact-method">
              <span class="method-icon">💼</span>
              <div>
                <p class="method-label">LinkedIn</p>
                <a href="https://www.linkedin.com/in/moehammad-alvaro-pirata-prayogo-842a8834a/" target="_blank">
                  Moehammad Alvaro Pirata Prayogo
                </a>
              </div>
            </div>

            <div class="contact-method">
              <span class="method-icon">⚙️</span>
